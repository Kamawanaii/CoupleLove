## Server
#HOST=0.0.0.0
#PORT=3001

## Public HTTPS URL where Railway serves your app (Telegram requires HTTPS)
# Example: https://your-service.up.railway.app
PUBLIC_APP_URL=

## Telegram bot settings (required for Telegram auth validation)
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=

## Optional UI name/subtitle
#APP_NAME=Для двоих
#APP_SUBTITLE=Личное mini app для двоих

## Bot polling (optional). If you want the bot to reply to /start from this server, enable it.
#ENABLE_BOT_POLLING=true

## Optional UI text
#MENU_BUTTON_TEXT=Open 291224

